rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: theaters
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - address: string (required)
    //   - city: string (required)
    //   - state: string (required, 2 chars)
    //   - state_long: string (required)
    //   - lat: number (required)
    //   - lng: number (required)
    //   - description: string (optional)
    //   - website: string (optional)
    //   - addedBy: string (optional)
    //   - createdAt: timestamp (optional)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "isobel78@gmail.com";
    }

    function isValidTheater(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.address is string && data.address.size() > 0 && data.address.size() < 300 &&
             data.city is string && data.city.size() > 0 && data.city.size() < 100 &&
             data.state is string && data.state.size() >= 2 && data.state.size() < 50 &&
             data.state_long is string && data.state_long.size() > 0 && data.state_long.size() < 100 &&
             data.lat is number &&
             data.lng is number &&
             (!('description' in data) || (data.description is string && data.description.size() < 1000)) &&
             (!('website' in data) || (data.website is string && data.website.size() < 500));
    }

    match /theaters/{theaterId} {
      allow read: if true;
      allow create: if isAdmin() && isValidTheater(request.resource.data);
      allow update: if isAdmin() && isValidTheater(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
